# Copy to .env and fill in values
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── Postgres + JWT (when set, API requires login; metadata in Postgres) ───
DATABASE_URL=postgresql://voicera:voicera@localhost:5432/voicera
# Optional streaming read replica URL — only /api/stats uses this pool (uploads always use DATABASE_URL)
# READ_DATABASE_URL=postgresql://voicera:voicera@replica-host:5432/voicera

# DB pools: per process. Rule: uvicorn_workers * DB_POOL_MAX_SIZE < Postgres max_connections (leave headroom)
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=20
DB_READ_POOL_MIN_SIZE=2
DB_READ_POOL_MAX_SIZE=20
DB_COMMAND_TIMEOUT=60
# 0 disables server-side statement timeout
DB_STATEMENT_TIMEOUT_MS=60000

JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# Set false in production if you only want admin-created users
ALLOW_OPEN_REGISTRATION=true

# S3-compatible object storage (MinIO, AWS S3, Alibaba OSS S3 endpoint, etc.)
# Leave credentials empty to store WAV only on server disk (storage_object_key local/...)
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=voicera-recordings
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
# path | virtual — use path for MinIO
S3_ADDRESSING_STYLE=path
# Optional CDN or browser-reachable MinIO URL for public_url(); leave empty for internal endpoint only
# S3_PUBLIC_BASE_URL=

# CORS: comma-separated frontend origins; leave empty or * for allow-all (dev only)
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: header X-Stats-Admin-Secret for org-wide /api/stats
STATS_ADMIN_SECRET=

# When true, also append JSONL lines to data/metadata.jsonl (in addition to Postgres when configured)
DUAL_WRITE_JSONL=true

# ── LLM prompt generation (optional) ─────────────────────────────────────────
PROMPTS_SOURCE=static
GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile
