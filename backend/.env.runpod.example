# Copy to backend/.env on the RunPod host and fill secrets.
# Pod proxy URL: https://<POD_ID>-8000.proxy.runpod.net  (POD_ID = segment before first dash in ssh host)

DEEPGRAM_API_KEY=

DATABASE_URL=postgresql://voicera:voicera@postgres:5432/voicera

DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=60
DB_STATEMENT_TIMEOUT_MS=60000

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ALLOW_OPEN_REGISTRATION=true

S3_ENDPOINT=http://minio:9000
S3_BUCKET=voicera-recordings
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
S3_ADDRESSING_STYLE=path

# Exact RunPod HTTPS proxy origin (comma-separate if multiple)
FRONTEND_ORIGINS=https://YOUR_POD_ID-8000.proxy.runpod.net

STATS_ADMIN_SECRET=
DUAL_WRITE_JSONL=true

PROMPTS_SOURCE=static
GROQ_API_KEY=
